    //Método próprio - Cria novo arquivo/verifica alterações não salvas
    private void newFile(){
        int result = checkUnsavedChanges();
        if (result != JOptionPane.CANCEL_OPTION) {
            textArea.setText("");
            currentFile = null;
            isModified = false;
            updateTitle();
            updateStatus();
        }
    }
    
    //Método próprio - Abre arquivos existentes
    private void openFile(){
        //Verifica se há alterações não salvas antes de abrir outro documento
        int result = checkUnsavedChanges();
        if(result != JOptionPane.CANCEL_OPTION){
            //Abre a janela de seleção de arquivo
            int returnValue = fileChooser.showOpenDialog(this);
            if(returnValue == JFileChooser.APPROVE_OPTION){
                String selectedFile = fileChooser.getSelectedFile().getAbsolutePath();
                
                String content = fileManager.openFile(selectedFile);
                if(content != null){
                    textArea.setText(content);
                    currentFile = selectedFile;
                    isModified = false;
                    updateTitle();
                    updateStatus();
                }
            }
        }
    }
    
    //Método próprio - Salva o arquivo atual
    private void saveFile(){
        if (currentFile == null) {
            saveAsFile();
        } else {
            boolean success = fileManager.saveFile(currentFile, textArea.getText());
            if (success) {
                isModified = false;
                updateTitle();
                JOptionPane.showMessageDialog(this,
                    "Arquivo salvo com sucesso!",
                    "Sucesso",
                    JOptionPane.INFORMATION_MESSAGE);
            }
        }
    }
    
    //Método próprio - Salva com um novo nome/local
    private void saveAsFile(){
        if (currentFile != null) {
            fileChooser.setSelectedFile(new File(currentFile));
        } else {
            fileChooser.setSelectedFile(new File("novo_arquivo.txt"));
        }
        
        int returnValue = fileChooser.showSaveDialog(this);
        
        if (returnValue == JFileChooser.APPROVE_OPTION) {
            String selectedFile = fileChooser.getSelectedFile().getAbsolutePath();
            
            if (!selectedFile.toLowerCase().endsWith(".txt")) {
                selectedFile += ".txt";
            }
            
            if (fileManager.fileExists(selectedFile)) {
                int confirm = JOptionPane.showConfirmDialog(this,
                    "O arquivo já existe. Deseja sobrescrevê-lo?",
                    "Confirmar substituição",
                    JOptionPane.YES_NO_OPTION);
                    
                if (confirm != JOptionPane.YES_OPTION) {
                    return;
                }
            }
            
            boolean success = fileManager.saveFile(selectedFile, textArea.getText());
            if (success) {
                currentFile = selectedFile;
                isModified = false;
                updateTitle();
                JOptionPane.showMessageDialog(this,
                    "Arquivo salvo com sucesso!",
                    "Sucesso",
                    JOptionPane.INFORMATION_MESSAGE);
            }
        }
    }
    
    //Método próprio - Verifica se há alterações não salvas
    private int checkUnsavedChanges(){
        if (isModified){
            int result = JOptionPane.showConfirmDialog(this,
                "Deseja salvar as alterações?",
                "Arquivo não salvo",
                JOptionPane.YES_NO_CANCEL_OPTION);
            
            if(result == JOptionPane.YES_OPTION){
                saveFile();
            }
            return result;
        }
        return JOptionPane.NO_OPTION;
    }
    
    //Método próprio - Fecha a aplicação com verificação
    private void exitApplication() {
        int result = checkUnsavedChanges();
        if (result != JOptionPane.CANCEL_OPTION) {
            System.exit(0);
        }
    }
    
