package com.mycompany.notepad;
import javax.swing.*;//Pacote grafico(botões, janelas "JFrame" etc)
import java.awt.*;//Pacote de layout e fontes (font toolkits)
import java.io.File;
import java.awt.event.*;

public class NotepadFrame extends JFrame {
    //Interface Grafica do Notepad
    
    //==========================================================================
    //Atributos da Classe
    //==========================================================================
    
    //Componente de texto multi-linhas do swing(Area de digitação)
    private JTextArea textArea;
    //Responsavel por operações de arquivo "Ler/Salvar"
    private FileManager fileManager;
    //Componente para seleção de arquivos
    private JFileChooser fileChooser;
    //Armazena o caminho do arquivo(onde ele está salvo)
    private String currentFile;
    //Flag para controlar se houveram modificações não salvas
    private boolean isModified;
    
    // Novos atributos para melhorias visuais
    // Rótulo que vai mostrar informações na barra inferior (linhas, caracteres e palavras)
private JLabel statusLabel;

// Painel que vai conter a barra de busca (campo de texto e botões)
private JPanel searchPanel;

// Controle para saber se a barra de busca está visível ou escondida
